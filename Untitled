                <span class="card-preco">R$ 180,00</span>
                <a href="https://wa.me/5585996543820" class="btn btn-primary btn-whatsapp" target="_blank">Compre Agora</a>
              </div>
            </div>
          </article>

          <article class="card-produto" data-product-id="flamengo-retro">
