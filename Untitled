        <img src="images/hero-messi.png" alt="" width="1920" height="1080" fetchpriority="high">
        <div class="hero-overlay"></div>
      </div>
      <div class="hero-content">
        <p class="hero-tag">Koala Sports</p>
        <h1 class="hero-title">Onde a paixão encontra a <span>qualidade</span>.</h1>
