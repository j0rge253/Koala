              <img src="" alt="Real Madrid Home" data-first>
              <span class="card-ver-fotos">Ver fotos</span>
              <div class="card-badge">1:1</div>
            </div>
            <div class="card-body">
              <span class="card-clube">Real Madrid</span>
              <h3 class="card-nome">Camisa Real Madrid Home 25-26</h3>
              <p class="card-desc">Qualidade Tailandesa 1:1. Bordados impecáveis.</p>
              <div class="card-footer">
                <span class="card-preco">R$ 180,00</span>
                <a href="https://wa.me/5585996543820" class="btn btn-primary btn-whatsapp" target="_blank">Compre Agora</a>
              </div>
            </div>
          </article>

          <article class="card-produto" data-product-id="manchester-city">
