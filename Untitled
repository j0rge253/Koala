    <div class="modal-galeria-backdrop"></div>
    <div class="modal-galeria-box">
      <button type="button" class="modal-galeria-close">&times;</button>
      <button type="button" class="modal-galeria-prev">&larr;</button>
      <div class="modal-galeria-slide">
        <img src="" alt="" id="modal-galeria-img">
      </div>
      <button type="button" class="modal-galeria-next">&rarr;</button>
      <div class="modal-galeria-dots" id="modal-galeria-dots"></div>
