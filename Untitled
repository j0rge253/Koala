<body>
  <header class="header">
    <div class="header-inner">
      <a href="#" class="logo-link">
        <img src="images/logo-koala-sports.png" alt="Koala Sports" class="logo-img" width="160" height="60" onerror="this.src='https://placehold.co/160x60/1a1a1a/ffffff?text=KOALA+SPORTS';">
